# OpGrid Workspace Server
# =========================
# Copy this to .env and fill in your values.

PORT=4101
HOST=0.0.0.0

# Workspace root directory to scan for projects
# Defaults to the current working directory if not set
WORKSPACE_PATH=/path/to/your/workspace

# In-memory presence timeout before agents are removed (milliseconds)
# Defaults to 180000 (3 minutes)
AGENT_STALE_TIMEOUT_MS=180000
